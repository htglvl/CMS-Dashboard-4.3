# CMS Dashboard Environment Variables
# Copy this file to .env and fill in your values

# Electricity North West API Key (required for data fetching and live incidents)
# Register at: https://electricitynorthwest.opendatasoft.com/
ENW_API_KEY=your_api_key_here

# AI API Key (required for OpenClaw natural language features)
# Choose one: XIAOMI_API_KEY, OPENAI_API_KEY, or ANTHROPIC_API_KEY
XIAOMI_API_KEY=your_api_key_here
# OPENAI_API_KEY=your_api_key_here
# ANTHROPIC_API_KEY=your_api_key_here
